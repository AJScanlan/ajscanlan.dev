---
const map = {
    note: { label: "Note" },
    tip: { label: "Tip" },
    warn: { label: "Warning" },
} as const;

type CalloutType = keyof typeof map;

interface CalloutProps {
    type?: CalloutType;
    title?: string;
}

const { type = "note", title } = Astro.props as CalloutProps;

const { label } = map[type];

const roleMap = {
    note: "note",
    tip: "complementary",
    warn: "alert"
} as const;
---
<div
    class="border border-ink-200 rounded-lg bg-paper-200 py-4 px-5 my-6"
    role={roleMap[type]}
    aria-label={title ?? label}
>
    <p class="font-mono text-2xs font-medium tracking-eyebrow uppercase text-ink-500 mb-1.5">{title ?? label}</p>
    <div class="text-sm text-ink-700">
        <slot />
    </div>
</div>
