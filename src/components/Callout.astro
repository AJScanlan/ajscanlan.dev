---
const map = {
    note: { label: "Note" },
    tip: { label: "Tip" },
    warn: { label: "Warning" },
} as const;

type CalloutType = keyof typeof map;

interface CalloutProps {
    type?: CalloutType;
    title?: string;
    icon?: boolean;
}

const { type = "note", title } = Astro.props as CalloutProps;

const { label } = map[type];

const roleMap = {
    note: "note",
    tip: "complementary",
    warn: "alert"
} as const;
---
<div
    class="callout"
    role={roleMap[type]}
    aria-label={title ?? label}
>
    <p class="callout-label">{title ?? label}</p>
    <div class="callout-body">
        <slot />
    </div>
</div>

<style>
    .callout {
        border: 1px solid var(--ink-200);
        border-radius: 8px;
        background: var(--paper-2);
        padding: 14px 20px;
        margin: 24px 0;
    }

    .callout-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--ink-500);
        margin: 0 0 6px;
    }

    .callout-body {
        font-size: 13px;
        line-height: 1.55;
        color: var(--ink-700);
    }
</style>
