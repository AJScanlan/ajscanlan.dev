---
interface NavLink {
  href: string;
  label: string;
  isActive?: boolean;
  isExternal?: boolean;
}

const { pathname } = Astro.url;

const navLinks: NavLink[] = [
  { href: '/archive', label: 'Archive', isActive: pathname.startsWith('/archive') },
  { href: '/about', label: 'About', isActive: pathname.startsWith('/about') },
  { href: 'https://github.com/AJScanlan', label: 'GitHub', isExternal: true },
  { href: '/feed.xml', label: 'RSS' },
];
---

<nav aria-label="Main navigation" class="sticky top-0 z-50 bg-paper-100 border-b border-ink-100">
  <div class="layout-home flex items-center justify-between h-14 py-3">
    {/* Brand */}
    <a href="/" class="flex items-center gap-2 no-underline text-ink-900 transition-colors duration-[120ms] hover:text-fox-ink">
      <div class="fox-mark size-[22px] shrink-0 bg-fox-500"></div>
      <span class="font-mono text-sm font-semibold text-inherit">ajscanlan.dev</span>
    </a>

    {/* Nav Links */}
    <div class="flex items-center gap-5">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'font-mono text-sm text-ink-500 no-underline whitespace-nowrap transition-colors duration-[120ms] hover:text-fox-ink',
            { 'text-ink-900 font-semibold': link.isActive },
          ]}
          {...(link.isExternal && { target: '_blank', rel: 'noopener noreferrer' })}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>

  <style>
    /* clip-path has no Tailwind utility — intentional exception */
    .fox-mark {
      clip-path: polygon(50% 0%, 100% 30%, 85% 100%, 15% 100%, 0% 30%);
    }
  </style>
</nav>
