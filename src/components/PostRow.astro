---
interface Props {
  date: Date;
  title: string;
  dek?: string;
  kind: 'project-log' | 'technical' | 'cheat-sheet' | 'note' | 'essay';
  slug: string;
  readingTime?: number;
  variant?: 'home' | 'archive';
}

const { date, title, dek, kind, slug, readingTime, variant = 'home' } = Astro.props;

const href = `/posts/${slug}/`;

const formatHomeDate = (d: Date): string => {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
};

const formatArchiveDate = (d: Date): string => {
  return d.toISOString().slice(0, 10);
};

const formatReadingTime = (minutes?: number): string => {
  if (!minutes) return '';
  return `${minutes} min`;
};

const getKindColor = (k: string): { color: string; bg: string; border: string } => {
  if (k === 'project-log') {
    return {
      color: 'var(--fox-ink)',
      bg: 'rgba(138, 34, 28, 0.06)',
      border: '1px solid rgba(138, 34, 28, 0.2)',
    };
  }
  return {
    color: 'var(--ink-400)',
    bg: 'transparent',
    border: '1px solid var(--ink-200)',
  };
};

const kindStyle = getKindColor(kind);
---

{variant === 'home' ? (
  <a href={href} class="post-row-home">
    <div class="date">{formatHomeDate(date)}</div>
    <div class="title-dek">
      <div class="title">{title}</div>
      {dek && <div class="dek">{dek}</div>}
    </div>
    <div class="kind-pill" style={`color: ${kindStyle.color}; background: ${kindStyle.bg}; border: ${kindStyle.border};`}>
      {kind.toUpperCase()}
    </div>
  </a>
) : (
  <a href={href} class="post-row-archive">
    <div class="iso-date">{formatArchiveDate(date)}</div>
    <div class="kind-text" style={`color: ${kindStyle.color};`}>{kind.toUpperCase()}</div>
    <div class="title">{title}</div>
    <div class="reading-time">{formatReadingTime(readingTime)}</div>
  </a>
)}

<style>
  a {
    text-decoration: none;
    display: grid;
    border-bottom: 1px solid var(--ink-100);
    padding: 11px 0;
    transition: background 120ms ease-out, color 120ms ease-out;
  }

  /* HOME VARIANT */
  .post-row-home {
    grid-template-columns: 100px 1fr 140px;
    gap: 24px;
    align-items: baseline;
    cursor: pointer;
  }

  .post-row-home:hover .title {
    color: var(--fox-ink);
  }

  .post-row-home .title::after {
    content: ' →';
    color: var(--ink-300);
    opacity: 0;
    display: inline-block;
    margin-left: 0;
    transition: opacity 120ms ease-out;
  }

  .post-row-home:hover .title::after {
    opacity: 1;
  }

  .date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--ink-400);
  }

  .title-dek {
    min-width: 0;
  }

  .title {
    font-size: 15px;
    font-weight: 500;
    color: var(--ink-900);
    transition: color 120ms ease-out;
  }

  .dek {
    font-size: 12.5px;
    color: var(--ink-500);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 48ch;
  }

  .kind-pill {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    border-radius: 3px;
    padding: 1px 7px;
    display: inline-block;
    white-space: nowrap;
  }

  /* ARCHIVE VARIANT */
  .post-row-archive {
    grid-template-columns: 110px 110px 1fr 80px;
    gap: 16px;
    align-items: baseline;
    cursor: pointer;
  }

  .post-row-archive:hover {
    background: var(--paper-2);
  }

  .post-row-archive:hover .title {
    color: var(--fox-ink);
  }

  .iso-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px;
    color: var(--ink-400);
  }

  .kind-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
  }

  .post-row-archive .title {
    font-size: 12.5px;
    font-weight: 500;
    color: var(--ink-900);
    transition: color 120ms ease-out;
  }

  .reading-time {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px;
    color: var(--ink-400);
    text-align: right;
  }
</style>
