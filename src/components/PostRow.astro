---
interface Props {
  date: Date;
  title: string;
  dek?: string;
  kind: 'project-log' | 'technical' | 'cheat-sheet' | 'note' | 'essay';
  slug: string;
  readingTime?: number;
  variant?: 'home' | 'archive';
}

const { date, title, dek, kind, slug, readingTime, variant = 'home' } = Astro.props;

const href = `/posts/${slug}/`;

const formatHomeDate = (d: Date): string => {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
};

const formatArchiveDate = (d: Date): string => {
  return d.toISOString().slice(0, 10);
};

const formatReadingTime = (minutes?: number): string => {
  if (!minutes) return '';
  return `${minutes} min`;
};

const getKindClasses = (k: string): { color: string; bg: string; border: string } => {
  if (k === 'project-log') {
    return {
      color: 'text-fox-ink',
      bg: 'bg-fox-ink/5',
      border: 'border border-fox-ink/20',
    };
  }
  return {
    color: 'text-ink-400',
    bg: 'bg-transparent',
    border: 'border border-ink-200',
  };
};

const kindClasses = getKindClasses(kind);
---

{variant === 'home' ? (
  <a href={href} class="post-row-home group grid no-underline border-b border-ink-100 py-3 transition-[background,color] duration-[120ms] ease-out gap-6 items-baseline cursor-pointer">
    <div class="font-mono text-xs text-ink-400">{formatHomeDate(date)}</div>
    <div class="min-w-0">
      <div class={`text-base font-medium text-ink-900 transition-colors duration-[120ms] ease-out group-hover:text-fox-ink post-row-title`}>{title}</div>
      {dek && <div class="text-sm text-ink-500 overflow-hidden text-ellipsis whitespace-nowrap max-w-[48ch]">{dek}</div>}
    </div>
    <div class={`font-mono text-xs font-medium uppercase rounded py-px px-2 inline-block whitespace-nowrap ${kindClasses.color} ${kindClasses.bg} ${kindClasses.border}`}>
      {kind.toUpperCase()}
    </div>
  </a>
) : (
  <a href={href} class="post-row-archive group grid no-underline border-b border-ink-100 py-3 transition-[background,color] duration-[120ms] ease-out gap-4 items-baseline cursor-pointer hover:bg-paper-200">
    <div class="font-mono text-xs text-ink-400">{formatArchiveDate(date)}</div>
    <div class={`font-mono text-xs font-medium uppercase ${kindClasses.color}`}>{kind.toUpperCase()}</div>
    <div class="text-sm font-medium text-ink-900 transition-colors duration-[120ms] ease-out group-hover:text-fox-ink">{title}</div>
    <div class="font-mono text-xs text-ink-400 text-right">{formatReadingTime(readingTime)}</div>
  </a>
)}

<style>
  /* HOME VARIANT — grid track sizes have no utility equivalent */
  .post-row-home {
    grid-template-columns: 100px 1fr 140px;
  }

  /* Arrow pseudo-element — requires ::after content, no utility equivalent */
  .post-row-title::after {
    content: ' →';
    color: #a0a2a6; /* ink.300 */
    opacity: 0;
    display: inline-block;
    margin-left: 0;
    transition: opacity 120ms ease-out;
  }

  .post-row-home:hover .post-row-title::after {
    opacity: 1;
  }

  /* ARCHIVE VARIANT — grid track sizes have no utility equivalent */
  .post-row-archive {
    grid-template-columns: 110px 110px 1fr 80px;
  }
</style>
