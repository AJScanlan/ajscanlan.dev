---
interface Props {
  name: string;
  blurb: string;
  status: 'live' | 'in-progress' | 'archived';
  stack: string[];
  links: Array<{ label: string; url: string }>;
}

const { name, blurb, status, stack, links } = Astro.props;

const statusBg: Record<string, string> = {
  live:          'bg-green',
  'in-progress': 'bg-fox-500',
  archived:      'bg-ink-300',
};
---

<div class="project-card border border-ink-100 rounded-xl p-5 bg-paper-100 flex flex-col gap-4 transition-all duration-200 ease-in-out hover:border-ink-200">
  <div
    class={`self-start font-mono text-2xs font-semibold uppercase tracking-eyebrow rounded py-0.5 px-2 text-white ${statusBg[status]}`}
  >
    {status.replace('-', ' ')}
  </div>

  <h3 class="text-lg font-semibold text-ink-900 m-0 p-0">{name}</h3>

  <p class="text-sm text-ink-600 m-0 p-0">{blurb}</p>

  <div class="flex flex-wrap gap-1">
    {stack.map((item) => (
      <span class="font-mono text-xs rounded py-0.5 px-2 bg-paper-200 text-ink-600 border border-ink-100 inline-block">{item}</span>
    ))}
  </div>

  <div class="flex flex-wrap gap-3 mt-auto">
    {links.map((link) => (
      <a href={link.url} class="font-mono text-xs text-ink-500 no-underline transition-colors duration-[120ms] ease-in-out hover:text-fox-ink">
        {link.label}
      </a>
    ))}
  </div>
</div>

<style>
  /* Card hover: custom shadow has no clean Tailwind utility — deliberate exception */
  .project-card:hover {
    transform: translateY(-1px);
    box-shadow: 0 12px 28px -18px rgba(11, 11, 14, 0.18);
  }
</style>
