---
interface Props {
    variant?: 'diamond' | 'dots' | 'asterism';
    spacing?: 'normal' | 'tight' | 'loose';
}

const { variant = 'diamond', spacing = 'normal' } = Astro.props;

const spacingClasses = {
    tight: 'my-8',
    normal: 'my-12',
    loose: 'my-16',
};
---

<div
    class={`group flex items-center justify-center w-full text-center ${spacingClasses[spacing]}`}
    role="separator"
    aria-hidden="true"
>
    {variant === 'dots' ? (
        <span class="flex justify-center gap-2.5">
            <span class="block w-1 h-1 rounded-full bg-ink-200"></span>
            <span class="block w-1 h-1 rounded-full bg-ink-200"></span>
            <span class="block w-1 h-1 rounded-full bg-ink-200"></span>
        </span>
    ) : (
        <span class="text-ink-300 text-base tracking-[0.5em] opacity-60 motion-safe:transition-opacity motion-safe:duration-200 motion-safe:ease-in-out group-hover:opacity-80 dark:opacity-50 dark:group-hover:opacity-70">
            {variant === 'diamond' ? '◆' : '⁂'}
        </span>
    )}
</div>
