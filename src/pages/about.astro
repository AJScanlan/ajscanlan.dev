---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Callout from "@/components/Callout.astro";
---

<BaseLayout
    title="About - ajscanlan.dev"
    description="Alexander Scanlan — writing to understand; thinking in public."
>
    <article class="prose dark:prose-invert prose-text max-w-prose">
        <!-- Layer 1: 30-second gist -->
        <section class="mb-rhythm-12">
            <h1 class="mb-rhythm-4">About</h1>
            
            <div class="text-xl leading-relaxed text-ink-800 dark:text-ink-200 mb-rhythm-6">
                <p>
                    Writing my way to understanding. Thinking in public.
                </p>
            </div>

            <p class="text-lg text-ink-600 dark:text-ink-300">
                This is where I publish essays, field notes, and technical explorations — 
                mostly about philosophy, systems, decentralization.
            </p>
        </section>
    </article>
</BaseLayout>
