---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../utils/get-reading-time';

const [essays, notes, cheatSheets, logs, technical] = await Promise.all([
    getCollection('essays', e => e.data.status === 'published'),
    getCollection('notes', e => e.data.status === 'published'),
    getCollection('cheat-sheets', e => e.data.status === 'published'),
    getCollection('logs', e => e.data.status === 'published'),
    getCollection('technical', e => e.data.status === 'published'),
]);

const sortDate = (entry: any): Date =>
    'date' in entry.data ? entry.data.date : entry.data.updated;

// Combine all entries into a unified list
const allPosts = [
    ...essays.map(e => ({ entry: e, kind: e.data.kind })),
    ...notes.map(e => ({ entry: e, kind: e.data.kind })),
    ...cheatSheets.map(e => ({ entry: e, kind: e.data.kind })),
    ...logs.map(e => ({ entry: e, kind: e.data.kind })),
    ...technical.map(e => ({ entry: e, kind: e.data.kind })),
].sort((a, b) => sortDate(b.entry).valueOf() - sortDate(a.entry).valueOf());

// Pre-calculate reading times
const postsWithRT = await Promise.all(
    allPosts.map(async ({ entry, kind }) => ({
        entry,
        kind,
        date: sortDate(entry),
        rt: await getReadingTime(entry),
    }))
);

// Group by year
const byYear = postsWithRT.reduce((acc, post) => {
    const year = post.date.getFullYear().toString();
    if (!acc[year]) acc[year] = [];
    acc[year].push(post);
    return acc;
}, {} as Record<string, typeof postsWithRT>);

const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a));

// Counts per kind for filter tabs
const counts = {
    all: postsWithRT.length,
    'project-log': postsWithRT.filter(p => p.kind === 'project-log').length,
    technical: postsWithRT.filter(p => p.kind === 'technical').length,
    'cheat-sheet': postsWithRT.filter(p => p.kind === 'cheat-sheet').length,
    note: postsWithRT.filter(p => p.kind === 'note').length,
    essay: postsWithRT.filter(p => p.kind === 'essay').length,
};
---

<BaseLayout title="Archive — ajscanlan.dev" description="All posts, sorted by date.">
    <div class="layout-home pt-12 pb-20">

        <h1 class="text-5xl font-bold text-ink-900 tracking-tight mb-6">Archive</h1>

        <div id="filter-tabs" class="flex flex-wrap gap-0 border-b border-ink-100 mb-8">
            <button class="tab font-mono text-sm py-2 px-3 text-ink-400 bg-transparent border-0 border-b-2 border-transparent -mb-px cursor-pointer transition-colors duration-[120ms] hover:text-ink-700" data-kind="all">All ({counts.all})</button>
            <button class="tab font-mono text-sm py-2 px-3 text-ink-400 bg-transparent border-0 border-b-2 border-transparent -mb-px cursor-pointer transition-colors duration-[120ms] hover:text-ink-700" data-kind="project-log">Project logs ({counts['project-log']})</button>
            <button class="tab font-mono text-sm py-2 px-3 text-ink-400 bg-transparent border-0 border-b-2 border-transparent -mb-px cursor-pointer transition-colors duration-[120ms] hover:text-ink-700" data-kind="technical">Technical ({counts.technical})</button>
            <button class="tab font-mono text-sm py-2 px-3 text-ink-400 bg-transparent border-0 border-b-2 border-transparent -mb-px cursor-pointer transition-colors duration-[120ms] hover:text-ink-700" data-kind="cheat-sheet">Cheat sheets ({counts['cheat-sheet']})</button>
            <button class="tab font-mono text-sm py-2 px-3 text-ink-400 bg-transparent border-0 border-b-2 border-transparent -mb-px cursor-pointer transition-colors duration-[120ms] hover:text-ink-700" data-kind="note">Notes ({counts.note})</button>
            <button class="tab font-mono text-sm py-2 px-3 text-ink-400 bg-transparent border-0 border-b-2 border-transparent -mb-px cursor-pointer transition-colors duration-[120ms] hover:text-ink-700" data-kind="essay">Essays ({counts.essay})</button>
        </div>

        <div id="archive-list">
            {years.map(year => (
                <div class="year-group mb-6" data-year={year}>
                    <div class="flex items-center gap-3 font-mono text-xs tracking-eyebrow uppercase text-ink-400 mb-1">
                        <span>{year}</span>
                        <span class="flex-1 h-px bg-ink-100"></span>
                    </div>
                    <div>
                        {byYear[year].map(({ entry, kind, date, rt }) => (
                            <a href={`/posts/${entry.slug}/`}
                               class="archive-row grid gap-4 py-3 border-b border-ink-100 items-baseline no-underline transition-colors duration-[120ms] hover:bg-paper-200"
                               style="grid-template-columns: 110px 110px 1fr 80px;"
                               data-kind={kind}>
                                <span class="font-mono text-xs text-ink-400">{date.toISOString().slice(0, 10)}</span>
                                <span class={`arc-kind font-mono text-xs uppercase tracking-wider ${kind === 'project-log' ? 'text-fox-ink' : 'text-ink-400'}`}>{kind}</span>
                                <span class="text-sm font-medium text-ink-900">{entry.data.title}</span>
                                <span class="arc-time font-mono text-xs text-ink-400 text-right">{rt} min</span>
                            </a>
                        ))}
                    </div>
                </div>
            ))}
        </div>

    </div>
</BaseLayout>

<style>
/* Active tab state — toggled by JS via .active class */
.tab.active {
    color: theme('colors.ink.900');
    border-bottom-color: theme('colors.ink.900');
    font-weight: 600;
}

/* data-hidden attribute drives show/hide filtering */
.archive-row[data-hidden],
.year-group[data-hidden] {
    display: none;
}

/* Responsive grid: 640px breakpoint preserved exactly */
@media (max-width: 640px) {
    .archive-row {
        grid-template-columns: 90px 1fr !important;
        grid-template-rows: auto auto;
    }
    .arc-kind { display: none; }
    .arc-time {
        text-align: left;
        color: theme('colors.ink.300');
    }
}
</style>

<script>
const tabs = document.querySelectorAll<HTMLElement>('.tab');
const rows = document.querySelectorAll<HTMLElement>('.archive-row');
const yearGroups = document.querySelectorAll<HTMLElement>('.year-group');

function activate(kind: string) {
    tabs.forEach(t => t.classList.toggle('active', t.dataset.kind === kind));

    rows.forEach(row => {
        const show = kind === 'all' || row.dataset.kind === kind;
        row.toggleAttribute('data-hidden', !show);
    });

    yearGroups.forEach(group => {
        const hasVisible = [...group.querySelectorAll('.archive-row')]
            .some(r => !r.hasAttribute('data-hidden'));
        group.toggleAttribute('data-hidden', !hasVisible);
    });

    const url = new URL(window.location.href);
    if (kind === 'all') {
        url.searchParams.delete('type');
    } else {
        url.searchParams.set('type', kind);
    }
    history.replaceState({}, '', url.toString());
}

const initialKind = new URL(window.location.href).searchParams.get('type') ?? 'all';
activate(initialKind);

tabs.forEach(tab => {
    tab.addEventListener('click', () => activate(tab.dataset.kind ?? 'all'));
});
</script>
