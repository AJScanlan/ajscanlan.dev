---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../utils/get-reading-time';
import ProjectCard from '../components/ProjectCard.astro';
import PostRow from '../components/PostRow.astro';
import Eyebrow from '../components/Eyebrow.astro';

// Projects — sort by order field
const projects = (await getCollection('projects'))
    .filter(p => p.data.featured)
    .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

// All content collections
const [essays, notes, cheatSheets, logs, technical] = await Promise.all([
    getCollection('essays', e => e.data.status === 'published'),
    getCollection('notes', e => e.data.status === 'published'),
    getCollection('cheat-sheets', e => e.data.status === 'published'),
    getCollection('logs', e => e.data.status === 'published'),
    getCollection('technical', e => e.data.status === 'published'),
]);

// Helper to get sortDate from any entry
const sortDate = (entry: any): Date =>
    'date' in entry.data ? entry.data.date : entry.data.updated;

// Section 1: project-log + technical (combined, sort by date desc, show latest 4)
const engineeringPosts = [...logs, ...technical]
    .sort((a, b) => sortDate(b).valueOf() - sortDate(a).valueOf())
    .slice(0, 4);

// Section 2: cheat-sheets + notes (combined, sort by date desc, show latest 3)
const referencePosts = [...cheatSheets, ...notes]
    .sort((a, b) => sortDate(b).valueOf() - sortDate(a).valueOf())
    .slice(0, 3);

// Section 3: essays (sort by date desc, show latest 3)
const essayPosts = essays
    .sort((a, b) => sortDate(b).valueOf() - sortDate(a).valueOf())
    .slice(0, 3);

// Pre-calculate reading times
const withReadingTime = async (entries: any[]) =>
    Promise.all(entries.map(async e => ({ entry: e, rt: await getReadingTime(e) })));

const [engWithRT, refWithRT, essayWithRT] = await Promise.all([
    withReadingTime(engineeringPosts),
    withReadingTime(referencePosts),
    withReadingTime(essayPosts),
]);
---

<BaseLayout title="ajscanlan.dev" description="Working notebook — engineering, writing, and the space between.">
    <div class="layout-home">

        <!-- Section 1: Hero -->
        <section class="pt-16 pb-2">
            <div class="inline-flex items-center gap-1.5 font-mono text-2xs uppercase tracking-eyebrow text-ink-400 mb-5">
                <span class="w-1.5 h-1.5 rounded-full bg-green flex-shrink-0"></span>
                Dublin, Ireland · Remote
            </div>
            <h1 class="text-4xl min-[700px]:text-6xl font-bold tracking-tight text-ink-900 mb-4">
                A.J. Scanlan — <span class="text-fox-ink">engineer</span>,<br/>
                learning out loud.
            </h1>
            <p class="text-base text-ink-600 max-w-[56ch] mb-6">
                Senior software engineer with over a decade of experience in native mobile development. iOS specialist. Currently interested in AI, distributed systems, and decentralised networks. 
            </p>
            <div class="flex items-center gap-2.5 font-mono text-sm text-ink-500">
                <a href="mailto:hi@ajscanlan.dev" class="text-ink-700 no-underline hover:text-fox-ink">hi@ajscanlan.dev</a>
                <span class="text-ink-300">·</span>
                <a href="https://github.com/AJScanlan" target="_blank" rel="noopener noreferrer" class="text-ink-700 no-underline hover:text-fox-ink">GitHub</a>
                <span class="text-ink-300">·</span>
                <a href="/about" class="text-ink-700 no-underline hover:text-fox-ink">More about me</a>
            </div>
        </section>

        <!-- Section 2: Selected Projects -->
        <section class="mt-16">
            <Eyebrow text="Selected Projects" />
            <div class="mt-4 grid grid-cols-1 min-[700px]:grid-cols-2 gap-4">
                {projects.map(p => (
                    <ProjectCard
                        name={p.data.name}
                        blurb={p.data.blurb}
                        status={p.data.status}
                        stack={p.data.stack}
                        links={p.data.links}
                    />
                ))}
            </div>
        </section>

        <!-- Section 3: Engineering & Technical Writing -->
        <section class="mt-16">
            <Eyebrow text="Projects & Technical Writing" />
            <div class="mt-3">
                {engWithRT.map(({ entry, rt }) => (
                    <PostRow
                        date={sortDate(entry)}
                        title={entry.data.title}
                        dek={entry.data.dek}
                        kind={entry.data.kind}
                        slug={entry.slug}
                        readingTime={rt}
                    />
                ))}
            </div>
            <a href="/archive?type=project-log" class="inline-block mt-3 font-mono text-xs text-ink-500 no-underline hover:text-fox-ink">See all →</a>
        </section>

        <!-- Section 4: References & Cheat Sheets -->
        <section class="mt-16">
            <Eyebrow text="References & Cheat Sheets" />
            <div class="mt-3">
                {refWithRT.map(({ entry, rt }) => (
                    <PostRow
                        date={sortDate(entry)}
                        title={entry.data.title}
                        dek={entry.data.dek}
                        kind={entry.data.kind}
                        slug={entry.slug}
                        readingTime={rt}
                    />
                ))}
            </div>
            <a href="/archive?type=cheat-sheet" class="inline-block mt-3 font-mono text-xs text-ink-500 no-underline hover:text-fox-ink">See all →</a>
        </section>

        <!-- Section 5: Essays -->
        <section class="mt-16">
            <Eyebrow text="Essays" />
            <div class="mt-3">
                {essayWithRT.map(({ entry, rt }) => (
                    <PostRow
                        date={sortDate(entry)}
                        title={entry.data.title}
                        dek={entry.data.dek}
                        kind={entry.data.kind}
                        slug={entry.slug}
                        readingTime={rt}
                    />
                ))}
            </div>
            <a href="/archive?type=essay" class="inline-block mt-3 font-mono text-xs text-ink-500 no-underline hover:text-fox-ink">See all →</a>
        </section>

    </div>
</BaseLayout>
