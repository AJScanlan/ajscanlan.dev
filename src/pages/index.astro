---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { formatReadingTime } from "@/utils/reading-time";
import { getReadingTime } from "@/utils/get-reading-time";

const collectionLabels = {
	thoughts: "Thought",
	notes: "Note",
	"cheat-sheets": "Cheat Sheet",
	logs: "Project Log",
} as const;

type CollectionKey = keyof typeof collectionLabels;

const collections = ["thoughts", "notes", "cheat-sheets", "logs"] as const;

const allEntries = (
	await Promise.all(
		collections.map(async (col) => {
			const entries = await getCollection(
				col,
				({ data }) => data.status === "published",
			);
			return entries.map((entry) => ({
				entry,
				collection: col as CollectionKey,
				sortDate:
					"date" in entry.data && entry.data.date
						? (entry.data.date as Date)
						: (entry.data.updated as Date),
			}));
		}),
	)
)
	.flat()
	.sort((a, b) => b.sortDate.valueOf() - a.sortDate.valueOf())
	.slice(0, 8);

// Pre-calculate reading times for all posts
const postsWithReadingTime = await Promise.all(
	allEntries.map(async ({ entry, collection, sortDate }) => ({
		entry,
		collection,
		sortDate,
		readingTime: await getReadingTime(entry),
	})),
);
---

<BaseLayout
	title="ajscanlan.dev"
	description="Writing my way to understanding."
>
	<section class="mb-12">
		<h1 class="text-3xl font-semibold tracking-tight mb-3">
			Writing my way to understanding
		</h1>
		<p class="text-ink-600 dark:text-ink-400 max-w-prose">
			Short, sincere, approachable reflections — clarity over flair.
			Occasionally technical, often humane.
		</p>
	</section>

	<section>
		<h2 class="text-xl font-semibold mb-4">Latest posts</h2>
		<ul class="space-y-5">
			{
				postsWithReadingTime.map(({ entry, collection, sortDate, readingTime }) => (
					<li>
						<a href={`/posts/${entry.slug}/`} class="block">
							<h3 class="text-lg font-medium hover:underline">
								{entry.data.title}
							</h3>
							{entry.data.dek && (
								<p class="text-sm text-ink-600 dark:text-ink-400">
									{entry.data.dek}
								</p>
							)}
							<p class="text-xs text-ink-500 mt-0.5">
								<span class="text-fox-500 font-medium">
									{collectionLabels[collection]}
								</span>
								{" "}·{" "}
								<time>
									{sortDate.toLocaleDateString("en-IE", {
										year: "numeric",
										month: "short",
										day: "2-digit",
									})}
								</time>
								{" "}· {formatReadingTime(readingTime)}
							</p>
						</a>
					</li>
				))
			}
		</ul>
	</section>
</BaseLayout>
