---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Callout from "@/components/Callout.astro";
import Eyebrow from "@/components/Eyebrow.astro";
import ReadingProgress from "@/components/ReadingProgress.astro";
import SectionBreak from "@/components/SectionBreak.astro";
import { getReadingTime } from "@/utils/get-reading-time";

export async function getStaticPaths() {
    const { getCollection } = await import("astro:content");

    // Collect all content types (excluding drafts)
    const collections = ['essays', 'notes', 'cheat-sheets', 'logs', 'technical'] as const;

    const allPosts = await Promise.all(
        collections.map(async (collection) => {
            const posts = await getCollection(
                collection,
                ({ data }) => data.status === "published",
            );
            return posts.map((post) => ({
                params: { slug: post.slug },
                props: { collection, entry: post },
            }));
        })
    );

    return allPosts.flat();
}

const { slug } = Astro.params;
const { entry: propsEntry } = Astro.props;

const entry = propsEntry;
if (!entry) throw new Error(`Post not found: ${slug}`);

const { Content } = await entry.render();
const { data } = entry;

const kind = 'kind' in data ? data.kind : 'note';
const postDate = 'date' in data ? data.date : data.updated;
const formattedDate = postDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

// Get reading time (from frontmatter or calculated)
const readingTime = await getReadingTime(entry);
---

<BaseLayout
    title={`${data.title} — ajscanlan.dev`}
    description={data.dek ?? data.title}
>
    <div class="layout-home">
        <ReadingProgress />

        <div class="max-w-[660px]">
            <div class="flex items-center gap-2.5 flex-wrap font-mono text-sm text-ink-400 mb-6 pt-6 sm:pt-10">
                <a href="/archive" class="meta-back text-ink-500 no-underline border-b border-ink-200 hover:text-fox-ink hover:border-fox-ink">← all posts</a>
                <span class="text-ink-200">·</span>
                <span class="font-mono uppercase tracking-wider text-xs rounded py-px px-2 bg-fox-500/5 text-fox-ink border border-fox-ink/25" data-kind={kind}>{kind}</span>
                <span class="text-ink-200">·</span>
                <time>{formattedDate}</time>
                <span class="text-ink-200">·</span>
                <span>{readingTime} min read</span>
            </div>

            <h1 class="text-5xl font-bold tracking-tight text-ink-900 mb-4">{data.title}</h1>

            {data.dek && <p class="font-serif italic text-lg text-ink-500 mb-8">{data.dek}</p>}

            <article class="post-prose text-base text-ink-700">
                <Content components={{ Callout, SectionBreak, Eyebrow }} />
            </article>
        </div>
    </div>
</BaseLayout>

<style>
/* :global() required — MDX-rendered elements don't receive Astro's scoped attribute */
.post-prose :global(p) { margin: 0 0 20px; }
.post-prose :global(ul) { list-style: disc; padding-left: 1.5rem; margin: 0 0 20px; }
.post-prose :global(ol) { list-style: decimal; padding-left: 1.5rem; margin: 0 0 20px; }
.post-prose :global(li) { margin-bottom: 0.5rem; }
.post-prose :global(.eyebrow + h2) { margin-top: 0.5rem; }
.post-prose :global(a) { color: theme('colors.fox.ink'); text-decoration: underline; text-underline-offset: 3px; }
.post-prose :global(a:hover) { color: theme('colors.fox.600'); }
.post-prose :global(blockquote) { border-left: 3px solid theme('colors.fox.ink'); margin: 0 0 20px; padding: 0.25rem 0 0.25rem 1.25rem; color: theme('colors.ink.500'); font-style: italic; }
.post-prose :global(blockquote p) { margin-bottom: 0.75rem; }
.post-prose :global(blockquote p:last-child) { margin-bottom: 0; }
</style>
