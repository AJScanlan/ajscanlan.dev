---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Callout from "@/components/Callout.astro";
import ReadingProgress from "@/components/ReadingProgress.astro";
import SectionBreak from "@/components/SectionBreak.astro";
import { getReadingTime } from "@/utils/get-reading-time";

export async function getStaticPaths() {
    const { getCollection } = await import("astro:content");

    // Collect all content types (excluding drafts)
    const collections = ['essays', 'notes', 'cheat-sheets', 'logs', 'technical'] as const;

    const allPosts = await Promise.all(
        collections.map(async (collection) => {
            const posts = await getCollection(
                collection,
                ({ data }) => data.status === "published",
            );
            return posts.map((post) => ({
                params: { slug: post.slug },
                props: { collection, entry: post },
            }));
        })
    );

    return allPosts.flat();
}

const { slug } = Astro.params;
const { entry: propsEntry } = Astro.props;

const entry = propsEntry;
if (!entry) throw new Error(`Post not found: ${slug}`);

const { Content } = await entry.render();
const { data } = entry;

const kind = 'kind' in data ? data.kind : 'note';
const postDate = 'date' in data ? data.date : data.updated;
const formattedDate = postDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

// Get reading time (from frontmatter or calculated)
const readingTime = await getReadingTime(entry);
---

<BaseLayout
    title={`${data.title} — ajscanlan.dev`}
    description={data.dek ?? data.title}
>
    <div class="layout-post">
        <ReadingProgress />

        <div class="meta-row">
            <a href="/archive" class="meta-back">← all posts</a>
            <span class="meta-sep">·</span>
            <span class="meta-kind" data-kind={kind}>{kind}</span>
            <span class="meta-sep">·</span>
            <time class="meta-date">{formattedDate}</time>
            <span class="meta-sep">·</span>
            <span class="meta-rt">{readingTime} min read</span>
        </div>

        <h1 class="post-h1">{data.title}</h1>

        {data.dek && <p class="post-dek">{data.dek}</p>}

        <article class="post-prose">
            <Content components={{ Callout, SectionBreak }} />
        </article>
    </div>
</BaseLayout>

<style>
.meta-row {
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
    font-family: 'JetBrains Mono', monospace; font-size: 12px;
    color: var(--ink-400); margin-bottom: 28px; padding-top: 40px;
}
.meta-back {
    color: var(--ink-500); text-decoration: none;
    border-bottom: 1px solid var(--ink-200);
}
.meta-back:hover { color: var(--fox-ink); border-bottom-color: var(--fox-ink); }
.meta-sep { color: var(--ink-200); }
.meta-kind {
    text-transform: uppercase; letter-spacing: 0.08em; font-size: 10.5px;
    border-radius: 3px; padding: 1px 7px;
    background: rgba(208, 52, 44, 0.04); color: var(--fox-ink);
    border: 1px solid rgba(138, 34, 28, 0.25);
}
.meta-date { color: var(--ink-400); }
.meta-rt   { color: var(--ink-400); }

.post-h1 {
    font-size: 2.75rem; font-weight: 700; letter-spacing: -0.025em;
    line-height: 1.08; color: var(--ink-900); margin: 0 0 14px;
}

.post-dek {
    font-family: ui-serif, 'Iowan Old Style', Charter, Georgia, serif;
    font-style: italic; font-size: 1.25rem; line-height: 1.5;
    color: var(--ink-500); margin: 0 0 36px;
}

.post-prose {
    font-size: 1.09375rem; /* 17.5px */
    line-height: 1.65;
    color: var(--ink-700);
}
.post-prose p { margin: 0 0 20px; }
</style>
